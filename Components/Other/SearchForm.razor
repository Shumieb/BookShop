 @inject NavigationManager NavigationManager
 @rendermode InteractiveServer

 <EditForm 
    Model="@searchModel" 
    OnValidSubmit="@HandleSearch" 
    class="@formStyles" 
    FormName="SearchForm"
>
    <DataAnnotationsValidator />    

    <div class="@inputsContainerStyles">
    <InputText class="@inputsTextStyles"
        placeholder="Author or Book Title"
        @bind-Value="searchModel.Query" 
    />

    <button 
        type="submit" 
        class="@buttonStyles"
    >
        Search
    </button>
</div>

    <div class="text-center">
        <ValidationMessage For="@(() => searchModel.Query)" />
    </div>
    
</EditForm>


@code{

    [Parameter] public string? formStyles { get; set; } 

    [Parameter] public string? inputsContainerStyles {get; set;}

    [Parameter] public string? inputsTextStyles {get; set;}

    [Parameter] public string? buttonStyles {get; set;}

    private SearchModel searchModel = new();

    private void HandleSearch()
    {
        string? term = searchModel.Query?.Trim();

        if (!string.IsNullOrWhiteSpace(term))
        {
            string? encoded = Uri.EscapeDataString(term);
            NavigationManager.NavigateTo($"/books?SearchTerm={encoded}");
        }    
    } 
}