 <EditForm 
    Model="@searchModel" 
    OnValidSubmit="@HandleSearch" 
    class="@formStyles" 
    FormName="SearchForm"
>
    <DataAnnotationsValidator />

    <div class="@inputsContainerStyles">
        <InputText class="@inputsTextStyles"
            placeholder="Author or Book Title"
            @bind-Value="searchModel.Query" 
        />

        <button 
            type="submit" 
            class="@buttonStyles"
        >
            Search
        </button>
    </div>

    <ValidationMessage For="@(() => searchModel.Query)" />
</EditForm>


@code{

    [Parameter]
    public string? formStyles { get; set; } 

    [Parameter]
    public string? inputsContainerStyles {get; set;}

    [Parameter]
    public string? inputsTextStyles {get; set;}

    [Parameter]
    public string? buttonStyles {get; set;}

    private SearchModel searchModel = new();

    private void HandleSearch()
    {
        //TODO: Handle your search logic here
        Console.WriteLine($"Searching for: {searchModel.Query}");
    } 
}