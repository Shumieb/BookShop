@using System.ComponentModel.DataAnnotations

<EditForm Model="@feedback" OnValidSubmit="@HandleSubmit" class="review-form mb-5">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <hr>
    <p class="fs-5 text-muted fst-italic text-center">We hope you enjoyed reading the book.</p>

    <div class="mb-3">
        <label class="form-label fw-bold fs-5">Book Rating (1–5)</label>
        <InputNumber class="form-control border-success" @bind-Value="feedback.BookRating" />
    </div>

    <div class="mb-5">
        <label class="form-label fw-bold fs-5">Book Review (optional)</label>
        <InputTextArea rows="5" class="form-control border-success" @bind-Value="feedback.BookReview" />
    </div>

    <hr>
    <p class="fs-5 text-muted fst-italic text-center">We hope you were happy with your delivery.</p>

    <div class="mb-3">
        <label class="form-label fw-bold fs-5">Delivery Rating (1–5)</label>
        <InputNumber class="form-control border-success" @bind-Value="feedback.DeliveryRating" />
    </div>

    <div class="mb-5">
        <label class="form-label fw-bold fs-5">Delivery Review (optional)</label>
        <InputTextArea rows="5" class="form-control border-success" @bind-Value="feedback.DeliveryReview" />
    </div>

    <hr>
    <p class="fs-5 text-muted fst-italic text-center">We hope you were happy with our Service.</p>

    <div class="mb-3">
        <label class="form-label fw-bold fs-5">Service Rating (1–5)</label>
        <InputNumber class="form-control border-success" @bind-Value="feedback.ServiceRating" />
    </div>

    <div class="mb-5">
        <label class="form-label fw-bold fs-5">Service Review (optional)</label>
        <InputTextArea rows="5" class="form-control border-success" @bind-Value="feedback.ServiceReview" />
    </div>

    <hr>

    <button class="btn btn-success w-100 fw-bold fs-5" type="submit">Submit Feedback</button>

    
</EditForm>

@code {
    private BookFeedback feedback = new();
    private bool submitted = false;

    private void HandleSubmit()
    {
        submitted = true;
        // Save to database or API here
    }
}
